    {
      "parameters": {
        "jsCode": "const metaItems = $items('Set Reporting Period');\nconst meta = (metaItems?.[0]?.json) ?? {};\nconst agentOut = $input.first().json;\nlet html = agentOut.output ?? agentOut.text ?? agentOut.response ?? agentOut.answer ?? agentOut.result ?? agentOut;\nif (typeof html !== 'string') { html = JSON.stringify(html, null, 2); }\nhtml = html.replace(/^```(?:html)?\\s*/i, '').replace(/\\s*```$/i, '');\nif (!/<[a-z][\\s\\S]*>/i.test(html)) {\n  const escape = (s) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');\n  html = `<pre style=\"white-space: pre-wrap;\">${escape(html)}</pre>`;\n}\nconst month = meta.report_month_name ?? '';\nconst year = meta.report_year ?? '';\nconst subject = `NovaCart Monthly Financial Standing Report � ${month} ${year}`.trim();\nreturn [{ json: { ...meta, report_subject: subject, report_html: html } }];"
      },
