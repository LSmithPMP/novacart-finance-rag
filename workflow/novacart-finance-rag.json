    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst firstOfThisMonth = new Date(now.getFullYear(), now.getMonth(), 1);\nconst lastOfPrevMonth = new Date(firstOfThisMonth.getTime() - 1);\nconst reportYear = lastOfPrevMonth.getFullYear();\nconst reportMonthIndex = lastOfPrevMonth.getMonth();\nconst reportMonth = reportMonthIndex + 1;\nconst monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];\nconst reportMonthName = monthNames[reportMonthIndex];\nconst periodStart = new Date(reportYear, reportMonthIndex, 1);\nconst periodEnd = new Date(reportYear, reportMonthIndex + 1, 0);\nconst fmt = (d) => d.toISOString().slice(0, 10);\nreturn [{ json: { generated_at: now.toISOString(), report_year: reportYear, report_month: reportMonth, report_month_name: reportMonthName, period_start: fmt(periodStart), period_end: fmt(periodEnd) } }];"
      },
      "id": "c44ce885-dff1-4164-8877-53fde52d6414",
      "name": "Set Reporting Period",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -704,
        -288
      ]
    },
    {
      "parameters": {
        "jsCode": "const meta = $json;\nconst chatInput = `Create the **Monthly Financial Standing Report** for NovaCart for **${meta.report_month_name} ${meta.report_year}** (period ${meta.period_start} to ${meta.period_end}).\\n\\nRequirements:\\n1) Use the Internal Finance vector store tool to pull internal performance (sales, units, revenue, margins, anomalies) for the month.\\n2) Use the External Market Reports vector store tool to pull market trends, competitor moves, macro conditions, and any relevant category insights.\\n3) Correlate internal performance with external conditions. Explicitly call out what likely drove results.\\n4) Provide a clear narrative plus tables where appropriate.\\n5) Output MUST be valid HTML (no Markdown, no code fences).\\n\\nFocus on decision-useful insights for executives. If any key data is missing, state assumptions and data gaps clearly.`;\nconst sessionId = `monthly_finance_report_${meta.report_year}_${String(meta.report_month).padStart(2,'0')}`;\nreturn [{ json: { ...meta, sessionId, chatInput, text: chatInput } }];"
      },
      "id": "addd3daf-01ba-49b2-919d-66f36add6530",
      "name": "Build Report Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        -288
      ]
    },
    {
      "parameters": {
        "options": {
          "systemMessage": "You are a senior finance & strategy analyst writing for NovaCart executives.\n\nYou MUST:\n- Use BOTH tools at least once: (1) Internal Finance Vector Store Tool and (2) External Market Reports Vector Store Tool.\n- Ground all key claims in retrieved evidence.\n- If evidence is insufficient for a claim, say so explicitly.\n\nOutput requirements:\n- Return a SINGLE HTML string only (no Markdown, no code fences).\n- Use simple inline CSS for email readability.\n- Structure the report with these sections:\n  1) Title + reporting period\n  2) Executive Summary (3-6 bullets)\n  3) KPI Dashboard (table)\n  4) Performance Deep Dive\n  5) Market Context\n  6) Drivers & Correlations\n  7) Risks, Opportunities, Recommendations\n  8) Sources"
        }
      },
      "id": "b67605cc-e37a-4ca0-8f79-0d75afa182f2",
      "name": "AI Finance Reporting Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
